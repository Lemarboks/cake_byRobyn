---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductOptions from '../../components/react/ProductOptions';
import { products, getProductBySlug } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const base    = import.meta.env.BASE_URL;
const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect(`${base}shop`);
}

const WA = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '27000000000';

const related = products
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 3);

const waEnquiry = encodeURIComponent(
  `Hi Robyn! I'm interested in the ${product.name} (${product.priceLabel}). Could you please provide more details? 🎂`
);
---

<BaseLayout
  title={product.name}
  description={product.description}
  ogImage={product.image}
>

  <!-- Breadcrumb -->
  <nav class="pt-28 pb-0 bg-cream-light px-6 md:px-10 max-w-7xl mx-auto" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-xs text-ink/50" role="list">
      <li><a href={base} class="hover:text-gold transition-colors">Home</a></li>
      <li aria-hidden="true" class="text-ink/30">/</li>
      <li><a href={`${base}shop`} class="hover:text-gold transition-colors">Shop</a></li>
      <li aria-hidden="true" class="text-ink/30">/</li>
      <li class="text-ink/70 truncate max-w-[200px]" aria-current="page">{product.name}</li>
    </ol>
  </nav>

  <!-- Product detail -->
  <section class="py-12 bg-cream-light" aria-label="Product detail">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Images -->
        <div class="space-y-3">
          <!-- Main image -->
          <div class="rounded-2xl overflow-hidden aspect-[4/5] border border-cream-dark">
            <img
              src={product.images[0] ?? product.image}
              alt={product.name}
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Thumbnails -->
          {product.images.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {product.images.map((img, i) => (
                <div class="rounded-lg overflow-hidden aspect-square border border-cream-dark">
                  <img
                    src={img.replace('?w=1200', '?w=200')}
                    alt={`${product.name} view ${i + 1}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Info + options -->
        <div class="lg:sticky lg:top-24 space-y-6">

          {product.badge && (
            <span class="inline-block px-4 py-1 bg-gold/10 text-gold text-xs font-semibold rounded-full border border-gold/30">
              {product.badge}
            </span>
          )}

          <div>
            <p class="section-label capitalize">{product.category.replace('-', ' ')}</p>
            <h1 class="font-serif text-3xl md:text-4xl text-ink mt-1">{product.name}</h1>
            <p class="font-script text-2xl text-gold mt-1">{product.tagline}</p>
          </div>

          <!-- Price + servings -->
          <div class="flex flex-wrap items-baseline gap-4 py-4 border-y border-cream-dark">
            <span class="text-2xl font-semibold text-gold font-serif">{product.priceLabel}</span>
            <span class="text-sm text-ink/50">{product.servings}</span>
          </div>

          <p class="text-ink/70 leading-relaxed text-sm">{product.description}</p>

          <!-- React options island -->
          <ProductOptions product={product} client:load />

          <!-- WhatsApp direct link -->
          <div class="pt-2 border-t border-cream-dark">
            <p class="text-xs text-ink/45 mb-3">Prefer to enquire first?</p>
            <a
              href={`https://wa.me/${WA}?text=${waEnquiry}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp w-full"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Enquire on WhatsApp
            </a>
          </div>

          <!-- Policy note -->
          <p class="text-xs text-ink/40 text-center">
            Orders confirmed with Robyn via WhatsApp. 50% deposit required to secure your date.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="py-16 bg-cream border-t border-cream-dark" aria-labelledby="related-heading">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="text-center mb-10">
          <span class="section-label">You might also love</span>
          <h2 id="related-heading" class="font-serif text-3xl text-ink mt-1">Related Cakes</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {related.map(p => (
            <a
              href={`${base}shop/${p.slug}`}
              class="group block rounded-xl overflow-hidden border border-cream-dark hover:border-gold/40 bg-cream-light card-lift"
              aria-label={`${p.name} — ${p.priceLabel}`}
            >
              <div class="overflow-hidden aspect-[4/5]">
                <img
                  src={p.image}
                  alt={p.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <h3 class="font-serif text-ink text-sm font-medium">{p.name}</h3>
                <p class="text-gold text-sm font-semibold mt-1">{p.priceLabel}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
