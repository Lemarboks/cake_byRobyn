---
import BaseLayout from '../layouts/BaseLayout.astro';

const WA = import.meta.env.PUBLIC_WHATSAPP_NUMBER  ?? '27000000000';
const IG = import.meta.env.PUBLIC_INSTAGRAM_HANDLE ?? 'cake_byrobyn';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Cake by Robyn. Reach us on WhatsApp, Instagram, or send an email. Based in Johannesburg, South Africa."
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <span class="section-label">We'd Love to Hear From You</span>
      <h1 class="font-script text-6xl md:text-7xl text-gold mt-2">Contact</h1>
      <p class="text-ink/60 mt-3 max-w-md mx-auto">
        For orders, enquiries, or just to say hello — reach us any time.
      </p>
    </div>
  </section>

  <section class="py-20 bg-cream-light" aria-label="Contact information">
    <div class="max-w-5xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Contact cards -->
        <div class="space-y-5 reveal">

          <!-- WhatsApp -->
          <a
            href={`https://wa.me/${WA}?text=${encodeURIComponent("Hi Robyn! I'd like to enquire about a custom cake. 🎂")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 p-6 rounded-xl border border-cream-dark bg-cream hover:border-[#25D366]/50 hover:shadow-md transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-full bg-[#25D366]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[#25D366]/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#25D366" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink text-sm">WhatsApp <span class="text-[#25D366] text-xs ml-1">(preferred)</span></p>
              <p class="text-ink/55 text-sm mt-0.5">Message us for orders and enquiries</p>
              <p class="text-[#25D366] text-xs mt-1 group-hover:underline">Chat now →</p>
            </div>
          </a>

          <!-- Instagram -->
          <a
            href={`https://www.instagram.com/${IG}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 p-6 rounded-xl border border-cream-dark bg-cream hover:border-gold/50 hover:shadow-md transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 group-hover:bg-gold/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-gold" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink text-sm">Instagram</p>
              <p class="text-ink/55 text-sm mt-0.5">@{IG}</p>
              <p class="text-gold text-xs mt-1 group-hover:underline">Follow for daily inspiration →</p>
            </div>
          </a>

          <!-- Email -->
          <div class="flex items-center gap-5 p-6 rounded-xl border border-cream-dark bg-cream">
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.75" strokeLinecap="round" strokeLinejoin="round" class="text-gold" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink text-sm">Email</p>
              <p class="text-ink/55 text-sm mt-0.5">
                <!-- Replace with real email when available -->
                hello@cakebyrobyn.co.za
              </p>
              <p class="text-xs text-ink/40 mt-1">Response within 24 hours</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-center gap-5 p-6 rounded-xl border border-cream-dark bg-cream">
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.75" strokeLinecap="round" strokeLinejoin="round" class="text-gold" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-ink text-sm">Location</p>
              <p class="text-ink/55 text-sm mt-0.5">Johannesburg, Gauteng, South Africa</p>
              <p class="text-xs text-ink/40 mt-1">Collection &amp; delivery available</p>
            </div>
          </div>
        </div>

        <!-- Quick message form (composes WhatsApp) -->
        <div class="reveal reveal-delay-1">
          <div class="bg-cream rounded-2xl p-7 border border-cream-dark">
            <h2 class="font-serif text-2xl text-ink mb-1">Send a quick message</h2>
            <p class="text-xs text-ink/50 mb-6">We'll reply via WhatsApp within a few hours.</p>

            <form id="contact-form" novalidate class="space-y-4" aria-label="Quick contact form">
              <div>
                <label for="c-name" class="form-label">Name <span aria-hidden="true" class="text-red-400">*</span></label>
                <input id="c-name" name="name" type="text" required placeholder="Your name" class="form-input" autocomplete="name" />
              </div>
              <div>
                <label for="c-subject" class="form-label">Subject</label>
                <input id="c-subject" name="subject" type="text" placeholder="e.g. Wedding cake quote" class="form-input" />
              </div>
              <div>
                <label for="c-message" class="form-label">Message <span aria-hidden="true" class="text-red-400">*</span></label>
                <textarea id="c-message" name="message" required rows="4" placeholder="Tell us what you need..." class="form-input resize-none"></textarea>
              </div>

              <div id="c-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded px-4 py-3" role="alert">
                Please fill in your name and message.
              </div>

              <button type="submit" class="btn-whatsapp w-full">
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Send via WhatsApp
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ WA }}>
  const form   = document.getElementById('contact-form');
  const errBox = document.getElementById('c-error');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data    = new FormData(form);
    const name    = data.get('name')?.toString().trim()    ?? '';
    const subject = data.get('subject')?.toString().trim() ?? '';
    const message = data.get('message')?.toString().trim() ?? '';

    if (!name || !message) {
      errBox.classList.remove('hidden');
      return;
    }
    errBox.classList.add('hidden');

    const lines = [
      `Hi Robyn! 👋`,
      ``,
      `*Name:* ${name}`,
      subject ? `*Subject:* ${subject}` : '',
      ``,
      message,
    ].filter(Boolean).join('\n');

    window.open(`https://wa.me/${WA}?text=${encodeURIComponent(lines)}`, '_blank', 'noopener');
  });
</script>
