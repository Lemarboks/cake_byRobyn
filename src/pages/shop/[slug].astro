---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductOptions from '../../components/react/ProductOptions';
import { products, getProductBySlug } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const base    = import.meta.env.BASE_URL;
const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect(`${base}shop`);
}

const related = products
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 3);
---

<BaseLayout
  title={product.name}
  description={product.description}
  ogImage={product.image}
>

  <!-- Breadcrumb -->
  <nav class="pt-28 pb-0 bg-cream-light px-6 md:px-10 max-w-7xl mx-auto" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-xs text-ink/50" role="list">
      <li><a href={base} class="hover:text-gold transition-colors">Home</a></li>
      <li aria-hidden="true" class="text-ink/30">/</li>
      <li><a href={`${base}shop`} class="hover:text-gold transition-colors">Shop</a></li>
      <li aria-hidden="true" class="text-ink/30">/</li>
      <li class="text-ink/70 truncate max-w-[200px]" aria-current="page">{product.name}</li>
    </ol>
  </nav>

  <!-- Product detail -->
  <section class="py-12 bg-cream-light" aria-label="Product detail">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Images -->
        <div class="space-y-3">
          <!-- Main image -->
          <div class="rounded-2xl overflow-hidden aspect-[4/5] border border-cream-dark">
            <img
              src={product.images[0] ?? product.image}
              alt={product.name}
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Thumbnails -->
          {product.images.length > 1 && (
            <div class="grid grid-cols-4 gap-2">
              {product.images.map((img, i) => (
                <div class="rounded-lg overflow-hidden aspect-square border border-cream-dark">
                  <img
                    src={img.replace('?w=1200', '?w=200')}
                    alt={`${product.name} view ${i + 1}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Info + options -->
        <div class="lg:sticky lg:top-24 space-y-6">

          {product.badge && (
            <span class="inline-block px-4 py-1 bg-gold/10 text-gold text-xs font-semibold rounded-full border border-gold/30">
              {product.badge}
            </span>
          )}

          <div>
            <p class="section-label capitalize">{product.category.replace('-', ' ')}</p>
            <h1 class="font-serif text-3xl md:text-4xl text-ink mt-1">{product.name}</h1>
            <p class="font-script text-2xl text-gold mt-1">{product.tagline}</p>
          </div>

          <!-- Price + servings -->
          <div class="flex flex-wrap items-baseline gap-4 py-4 border-y border-cream-dark">
            <span class="text-2xl font-semibold text-gold font-serif">{product.priceLabel}</span>
            <span class="text-sm text-ink/50">{product.servings}</span>
          </div>

          <p class="text-ink/70 leading-relaxed text-sm">{product.description}</p>

          <!-- React options island -->
          <ProductOptions product={product} client:load />

          <!-- Custom cake note -->
          <div class="pt-2 border-t border-cream-dark text-center">
            <p class="text-xs text-ink/45 mb-2">Need something fully bespoke?</p>
            <a href={`${base}enquiry`} class="text-xs text-gold hover:underline font-medium">
              Submit a Custom Cake Enquiry →
            </a>
          </div>

          <!-- Policy note -->
          <p class="text-xs text-ink/40 text-center">
            Secured checkout via PayFast · Card, EFT &amp; SnapScan accepted
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="py-16 bg-cream border-t border-cream-dark" aria-labelledby="related-heading">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="text-center mb-10">
          <span class="section-label">You might also love</span>
          <h2 id="related-heading" class="font-serif text-3xl text-ink mt-1">Related Cakes</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {related.map(p => (
            <a
              href={`${base}shop/${p.slug}`}
              class="group block rounded-xl overflow-hidden border border-cream-dark hover:border-gold/40 bg-cream-light card-lift"
              aria-label={`${p.name} — ${p.priceLabel}`}
            >
              <div class="overflow-hidden aspect-[4/5]">
                <img
                  src={p.image}
                  alt={p.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <h3 class="font-serif text-ink text-sm font-medium">{p.name}</h3>
                <p class="text-gold text-sm font-semibold mt-1">{p.priceLabel}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
