---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Robyn"
  description="Meet Robyn — the passionate pastry artist behind Cake by Robyn. Learn about our story, philosophy, and commitment to handcrafted bespoke cakes."
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <span class="section-label">The Story Behind the Cake</span>
      <h1 class="font-script text-6xl md:text-7xl text-gold mt-2">About Robyn</h1>
    </div>
  </section>

  <!-- Story section -->
  <section class="py-20 bg-cream-light" aria-label="About Robyn">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative reveal">
          <div class="rounded-2xl overflow-hidden aspect-[3/4] shadow-gold-md">
            <img
              src="https://images.unsplash.com/photo-1607478900766-efe13248b125?w=800&q=80"
              alt="Robyn crafting a bespoke cake with careful detail"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative offset border -->
          <div class="absolute -bottom-4 -right-4 w-full h-full border border-gold/30 rounded-2xl pointer-events-none -z-10"></div>
        </div>

        <!-- Text -->
        <div class="reveal reveal-delay-1 space-y-6">
          <div>
            <span class="section-label">Hello, I'm Robyn</span>
            <h2 class="font-serif text-4xl text-ink mt-1">Passion baked into every layer</h2>
          </div>

          <div class="space-y-4 text-ink/70 leading-relaxed">
            <p>
              Cake by Robyn began exactly the way the best things do — with love, a little flour,
              and a deep belief that food can make moments truly magical. Based in Johannesburg,
              I've spent years honing the craft of bespoke cake design, turning client visions
              into edible art that stops people mid-conversation.
            </p>
            <p>
              Every cake I create is a unique collaboration. I listen to your story, your colour
              palettes, your childhood memories of what a perfect cake should taste like — and I
              design something entirely yours. Not from a catalogue. Not from a template.
              Just for you.
            </p>
            <p>
              I work only with the finest ingredients — real butter, Belgian chocolate, fresh
              local produce, and flavours that actually taste like what they're called.
              Because a cake that looks incredible but tastes ordinary is only half a cake.
            </p>
          </div>

          <blockquote class="border-l-2 border-gold pl-6 py-1">
            <p class="font-script text-2xl text-gold">"A cake isn't just a dessert. It's the centrepiece of a memory."</p>
          </blockquote>

          <a href="/enquiry" class="btn-gold inline-flex">Work With Me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-cream" aria-labelledby="values-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-14 reveal">
        <span class="section-label">What I Stand For</span>
        <h2 id="values-heading" class="font-serif text-4xl text-ink mt-1">My Philosophy</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: '✦',
            title: 'Bespoke Always',
            desc: 'Every cake is designed from scratch for your specific brief. No two Robyn cakes are ever alike.',
          },
          {
            icon: '✦',
            title: 'Premium Ingredients',
            desc: 'Real butter, Belgian couverture chocolate, fresh eggs, and locally sourced fruits. No shortcuts.',
          },
          {
            icon: '✦',
            title: 'Personal Service',
            desc: 'You deal with me directly — from your first enquiry to the moment your cake is delivered.',
          },
          {
            icon: '✦',
            title: 'Obsessive Detail',
            desc: 'Whether it\'s a sugar petal or a fondant monogram, every element receives the same precision.',
          },
          {
            icon: '✦',
            title: 'Reliable & On-Time',
            desc: 'Your celebration is non-negotiable. I treat every deadline with the seriousness it deserves.',
          },
          {
            icon: '✦',
            title: 'Made with Love',
            desc: 'This isn\'t just a business. Every single cake carries genuine care for the person receiving it.',
          },
        ].map((val, i) => (
          <div class:list={['bg-cream-light rounded-xl p-7 border border-cream-dark reveal', `reveal-delay-${Math.min(i % 3 + 1, 4)}`]}>
            <span class="text-gold text-2xl" aria-hidden="true">{val.icon}</span>
            <h3 class="font-serif text-ink text-lg mt-3 mb-2">{val.title}</h3>
            <p class="text-ink/60 text-sm leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery teaser -->
  <section class="py-20 bg-cream-light" aria-labelledby="work-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-10 reveal">
        <span class="section-label">See the Work</span>
        <h2 id="work-heading" class="font-serif text-4xl text-ink mt-1">Some of My Favourites</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          'https://images.unsplash.com/photo-1535254973040-607b474cb50d?w=400&q=75',
          'https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=400&q=75',
          'https://images.unsplash.com/photo-1571115177098-24ec42ed204d?w=400&q=75',
          'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=400&q=75',
        ].map((src, i) => (
          <div class:list={['rounded-xl overflow-hidden aspect-square reveal', `reveal-delay-${i + 1}`]}>
            <img
              src={src}
              alt=""
              aria-hidden="true"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a href="/gallery" class="btn-outline-gold">View Full Gallery</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gold text-white text-center" aria-label="Get in touch">
    <div class="max-w-xl mx-auto px-6 reveal">
      <h2 class="font-script text-5xl text-white mb-4">Let's make something beautiful</h2>
      <p class="text-white/80 mb-7">
        Every celebration deserves a cake that matches the moment. Let's chat about yours.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/enquiry" class="px-8 py-3.5 bg-white text-gold font-semibold rounded hover:bg-cream-light transition-colors">
          Start an Enquiry
        </a>
        <a href="/contact" class="px-8 py-3.5 border border-white/60 text-white font-semibold rounded hover:bg-white/10 transition-colors">
          Contact
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
