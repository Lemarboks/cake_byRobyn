---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedProducts } from '../data/products';
import { reviews } from '../data/gallery';

const WA = import.meta.env.PUBLIC_WHATSAPP_NUMBER  ?? '27000000000';
const IG = import.meta.env.PUBLIC_INSTAGRAM_HANDLE ?? 'cake_byrobyn';

const featured = getFeaturedProducts();

const whyFeatures = [
  {
    icon: '✦',
    title: 'Bespoke Design',
    desc: 'Custom-designed for your vision, not from a template.',
  },
  {
    icon: '✦',
    title: 'Premium Ingredients',
    desc: 'Real butter, Belgian chocolate, and fresh flavours only.',
  },
  {
    icon: '✦',
    title: 'Punctual & Reliable',
    desc: 'Your celebration won\'t wait — neither will we.',
  },
  {
    icon: '✦',
    title: 'Personal Consultation',
    desc: 'We work with you from concept to your very first slice.',
  },
];

const igPlaceholders = [
  'https://images.unsplash.com/photo-1535254973040-607b474cb50d?w=400&q=75',
  'https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=400&q=75',
  'https://images.unsplash.com/photo-1571115177098-24ec42ed204d?w=400&q=75',
  'https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=400&q=75',
  'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=400&q=75',
  'https://images.unsplash.com/photo-1607478900766-efe13248b125?w=400&q=75',
];
---

<BaseLayout
  title="Custom Cakes Made with Love"
  description="Bespoke custom cakes for weddings, birthdays, and every celebration. Handcrafted with premium ingredients in Johannesburg."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════ -->
  <section
    class="relative min-h-screen flex items-center overflow-hidden"
    aria-label="Hero"
  >
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="/brand/hero-1.jpg"
        alt=""
        aria-hidden="true"
        class="w-full h-full object-cover object-center"
        onerror="this.parentElement.style.background='linear-gradient(135deg, #FAF6EF 0%, #EDE5D4 50%, #F7F1E8 100%)'"
      />
      <!-- Gentle left-side cream overlay so headline text stays legible -->
      <div class="absolute inset-0 bg-gradient-to-r from-cream-light/90 via-cream-light/60 to-transparent"></div>
    </div>

    <!-- Headline content — left side (in the cream negative space) -->
    <div class="relative z-10 max-w-7xl mx-auto w-full px-6 md:px-10 py-32">
      <div class="max-w-lg">
        <p class="section-label animate-fade-in" style="animation-delay:0.1s; animation-fill-mode:both">
          Handcrafted &nbsp;·&nbsp; Elevated &nbsp;·&nbsp; Unforgettable
        </p>

        <h1 class="font-script text-6xl md:text-7xl xl:text-8xl text-gold leading-tight mt-2 animate-fade-rise" style="animation-delay:0.2s; animation-fill-mode:both">
          Custom cakes<br />made with love
        </h1>

        <p class="text-ink/70 text-lg mt-5 leading-relaxed animate-fade-rise" style="animation-delay:0.4s; animation-fill-mode:both">
          Every cake is a one-of-a-kind creation, made with premium ingredients
          and an obsessive attention to detail.
        </p>

        <div class="flex flex-wrap gap-4 mt-8 animate-fade-rise" style="animation-delay:0.55s; animation-fill-mode:both">
          <a href="/shop"    class="btn-gold">Shop Cakes</a>
          <a href="/enquiry" class="btn-outline-gold">Custom Order</a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-fade-in" style="animation-delay:1.2s; animation-fill-mode:both" aria-hidden="true">
      <span class="text-xs tracking-widest text-ink/40 uppercase">Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-gold/60 to-transparent"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FEATURED CAKES
  ════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-cream" aria-labelledby="featured-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Signature Creations</span>
        <h2 id="featured-heading" class="text-4xl md:text-5xl font-serif text-ink mt-1">Featured Cakes</h2>
        <p class="text-ink/60 mt-3 max-w-md mx-auto">
          Each cake tells a story. Here are some of our most beloved creations.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featured.map((product, i) => (
          <a
            href={`/shop/${product.slug}`}
            class:list={['group block rounded-xl overflow-hidden bg-cream-light card-lift reveal', `reveal-delay-${Math.min(i + 1, 4)}`]}
            aria-label={`View ${product.name} — ${product.priceLabel}`}
          >
            <div class="card-img relative overflow-hidden aspect-[4/5]">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              {product.badge && (
                <span class="absolute top-3 left-3 px-3 py-1 bg-gold text-white text-xs font-semibold rounded-full">
                  {product.badge}
                </span>
              )}
              <div class="absolute inset-0 border border-transparent group-hover:border-gold/40 rounded-xl transition-all duration-300 pointer-events-none"></div>
            </div>
            <div class="p-4">
              <h3 class="font-serif text-ink text-base font-medium leading-tight">{product.name}</h3>
              <p class="text-gold text-sm font-semibold mt-1">{product.priceLabel}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/shop" class="btn-outline-gold">View All Cakes</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       WHY US
  ════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-cream-light" aria-labelledby="why-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Content -->
        <div class="reveal">
          <span class="section-label">The Robyn Difference</span>
          <h2 id="why-heading" class="text-4xl md:text-5xl font-serif text-ink mt-1 mb-6">
            Why Choose<br />
            <span class="gold-shimmer">Cake by Robyn</span>
          </h2>
          <p class="text-ink/65 leading-relaxed mb-8">
            Every cake is a one-of-a-kind creation, made with premium ingredients
            and an obsessive attention to detail. We don't just bake cakes — we craft experiences.
          </p>

          <ul class="space-y-5" role="list">
            {whyFeatures.map((feat, i) => (
              <li class:list={['flex gap-4 reveal', `reveal-delay-${i + 1}`]}>
                <span class="text-gold text-xl flex-shrink-0 mt-0.5" aria-hidden="true">{feat.icon}</span>
                <div>
                  <h3 class="font-serif font-medium text-ink text-base">{feat.title}</h3>
                  <p class="text-sm text-ink/60 mt-0.5">{feat.desc}</p>
                </div>
              </li>
            ))}
          </ul>

          <a href="/about" class="btn-outline-gold mt-8 inline-flex">Learn About Robyn</a>
        </div>

        <!-- Image -->
        <div class="relative reveal reveal-delay-2">
          <div class="rounded-2xl overflow-hidden aspect-[4/5] shadow-gold-md">
            <img
              src="https://images.unsplash.com/photo-1607478900766-efe13248b125?w=800&q=80"
              alt="Robyn at work crafting a bespoke cake"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Badge overlay -->
          <div class="absolute -bottom-5 -left-5 bg-gold text-white rounded-xl p-5 shadow-gold-md">
            <p class="font-script text-2xl leading-none">100%</p>
            <p class="text-xs font-semibold uppercase tracking-widest mt-1">Custom Made</p>
          </div>
          <!-- Gold border accent -->
          <div class="absolute -top-3 -right-3 w-full h-full border border-gold/30 rounded-2xl pointer-events-none -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       HOW IT WORKS
  ════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-ink text-white" aria-labelledby="process-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10 text-center">
      <div class="reveal">
        <span class="section-label !text-gold">Simple &amp; Easy</span>
        <h2 id="process-heading" class="text-4xl md:text-5xl font-serif text-white mt-1 mb-14">How It Works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 relative">
        <!-- Connecting line on md+ -->
        <div class="hidden md:block absolute top-7 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-gold/25"></div>

        {[
          { num: '01', title: 'Choose', desc: 'Browse the shop or fill in our custom order form with your occasion, size, flavour, and design inspiration.' },
          { num: '02', title: 'Confirm', desc: 'We\'ll send a detailed quote within 24 hours. Secure your date with a 50% deposit via WhatsApp.' },
          { num: '03', title: 'Enjoy', desc: 'Collect or receive your masterpiece, freshly made and beautifully packaged for your celebration.' },
        ].map((step, i) => (
          <div class:list={['flex flex-col items-center text-center reveal', `reveal-delay-${i + 1}`]}>
            <div class="w-14 h-14 rounded-full border border-gold/50 flex items-center justify-center text-gold font-serif text-lg font-medium mb-4 bg-ink relative z-10">
              {step.num}
            </div>
            <h3 class="font-serif text-white text-xl mb-2">{step.title}</h3>
            <p class="text-white/55 text-sm leading-relaxed max-w-xs mx-auto">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-14 reveal">
        <a href="/enquiry" class="btn-gold">Start Your Order</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       REVIEWS
  ════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-cream" aria-labelledby="reviews-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-14 reveal">
        <span class="section-label">Client Stories</span>
        <h2 id="reviews-heading" class="text-4xl md:text-5xl font-serif text-ink mt-1">What Our Clients Say</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.map((r, i) => (
          <figure
            class:list={[
              'rounded-xl p-7 reveal',
              `reveal-delay-${Math.min(i + 1, 4)}`,
              r.featured
                ? 'bg-gold text-white shadow-gold-lg'
                : 'bg-cream-light border border-cream-dark',
            ]}
          >
            <!-- Stars -->
            <div class:list={['flex gap-0.5 mb-4', r.featured ? 'text-white' : 'text-gold']} aria-label="5 stars">
              {'★★★★★'.split('').map(s => <span aria-hidden="true">{s}</span>)}
            </div>

            <blockquote class:list={['font-serif text-base italic leading-relaxed mb-5', r.featured ? 'text-white' : 'text-ink/80']}>
              "{r.quote}"
            </blockquote>

            <figcaption class="flex items-center gap-3">
              <div class:list={[
                'w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0',
                r.featured ? 'bg-white/20 text-white' : 'bg-gold text-white',
              ]} aria-hidden="true">
                {r.initials}
              </div>
              <div>
                <p class:list={['font-semibold text-sm', r.featured ? 'text-white' : 'text-ink']}>{r.author}</p>
                <p class:list={['text-xs', r.featured ? 'text-white/70' : 'text-ink/50']}>{r.occasion}</p>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       INSTAGRAM TEASER
  ════════════════════════════════════════════════════════════════ -->
  <section class="py-24 bg-cream-light" aria-labelledby="ig-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <div class="text-center mb-10 reveal">
        <span class="section-label">Follow Along</span>
        <h2 id="ig-heading" class="text-4xl md:text-5xl font-serif text-ink mt-1">
          <a
            href={`https://www.instagram.com/${IG}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-gold transition-colors duration-200"
          >
            @{IG}
          </a>
        </h2>
        <p class="text-ink/55 mt-3 text-sm">Fresh creations, behind-the-scenes moments, and sweet inspiration.</p>
      </div>

      <!-- 6-image grid -->
      <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
        {igPlaceholders.map((src, i) => (
          <a
            href={`https://www.instagram.com/${IG}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`View post ${i + 1} on Instagram`}
            class:list={['group relative overflow-hidden aspect-square rounded-lg reveal', `reveal-delay-${Math.min(i + 1, 4)}`]}
          >
            <img
              src={src}
              alt=""
              aria-hidden="true"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/35 transition-all duration-300 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="white" viewBox="0 0 24 24" class="opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10 reveal">
        <a
          href={`https://www.instagram.com/${IG}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline-gold"
        >
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FINAL CTA STRIP
  ════════════════════════════════════════════════════════════════ -->
  <section
    class="py-20 bg-gold text-white text-center relative overflow-hidden"
    aria-label="Order call to action"
  >
    <!-- Subtle pattern overlay -->
    <div class="absolute inset-0 opacity-5" aria-hidden="true"
         style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>

    <div class="relative max-w-2xl mx-auto px-6">
      <h2 class="font-script text-5xl md:text-6xl text-white mb-4 reveal">
        Ready to order?
      </h2>
      <p class="text-white/80 mb-8 text-lg reveal reveal-delay-1">
        Let's create something beautiful together. Start with a custom enquiry
        or browse the shop to begin your order.
      </p>
      <div class="flex flex-wrap justify-center gap-4 reveal reveal-delay-2">
        <a href="/enquiry" class="px-8 py-3.5 bg-white text-gold font-semibold rounded hover:bg-cream-light transition-colors">
          Custom Order
        </a>
        <a
          href={`https://wa.me/${WA}?text=${encodeURIComponent("Hi Robyn! I'd love to order a cake. 🎂")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3.5 border border-white/60 text-white font-semibold rounded hover:bg-white/10 transition-colors flex items-center gap-2"
        >
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
