# Copy this file to .env and fill in your values.
# PUBLIC_ prefix exposes the variable to browser-side code.

# Your WhatsApp number in international format WITHOUT the + sign
# e.g. 27821234567 for a South African number +27 82 123 4567
PUBLIC_WHATSAPP_NUMBER=27000000000

# Instagram handle WITHOUT the @ sign
PUBLIC_INSTAGRAM_HANDLE=cake_byrobyn

# Your site's canonical URL (used for OG tags & sitemap)
SITE_URL=https://cakebyrobyn.co.za
