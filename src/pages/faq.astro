---
import BaseLayout from '../layouts/BaseLayout.astro';

const WA = import.meta.env.PUBLIC_WHATSAPP_NUMBER  ?? '27000000000';
const IG = import.meta.env.PUBLIC_INSTAGRAM_HANDLE ?? 'cake_byrobyn';

const faqs = [
  {
    q: 'How far in advance should I order?',
    a: 'We recommend placing your order at least 2–3 weeks in advance for standard cakes, and 4–6 weeks for wedding cakes or large tiered cakes. For rush orders, please contact us directly via WhatsApp.',
  },
  {
    q: 'Do you offer delivery?',
    a: 'Yes! We offer delivery within Johannesburg. Delivery fees vary based on distance and will be included in your quote. For multi-tiered cakes, we strongly recommend delivery to ensure they arrive in perfect condition.',
  },
  {
    q: 'Can I send Pinterest or Instagram inspiration?',
    a: 'Absolutely — we encourage it! Share any inspiration photos when filling in the order form, or send them via WhatsApp. The more visual reference we have, the more accurately we can bring your vision to life.',
  },
  {
    q: 'What is your payment policy?',
    a: 'We require a 50% non-refundable deposit to secure your booking date. The remaining balance is due 3 days before collection or delivery. We accept EFT and major payment apps.',
  },
  {
    q: 'Do you cater for allergies or dietary requirements?',
    a: 'We can accommodate certain dietary requirements including gluten-free and dairy-free options. Please mention any allergies in your order form so we can advise on the best options for you.',
  },
  {
    q: 'What is your cancellation policy?',
    a: 'Deposits are non-refundable. If you need to reschedule, please do so at least 7 days before your order date and we\'ll do our best to accommodate a new date subject to availability.',
  },
  {
    q: 'Do you do tasting sessions?',
    a: 'Tasting sessions are available for wedding cake bookings. Please mention this in your order form and we\'ll arrange a time that works for you.',
  },
  {
    q: 'Can I request a cake not shown in the gallery?',
    a: 'Absolutely. Our gallery is just a sample of what we\'ve created — we love a new challenge. Share your ideas and we\'ll let you know what\'s possible.',
  },
  {
    q: 'What flavours are available?',
    a: 'We offer Classic Vanilla, Rich Chocolate, Red Velvet, Lemon Drizzle, Strawberry, and Salted Caramel as standard flavours. Custom flavours can be requested — just ask!',
  },
  {
    q: 'How should I store and serve my cake?',
    a: 'Cakes should be stored in a cool, dry place or refrigerated. Remove from the fridge 30–60 minutes before serving for the best flavour and texture. Specific storage instructions will be provided with your order.',
  },
];
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about ordering, delivery, payment, allergies, and cancellations at Cake by Robyn. Johannesburg bespoke cake studio."
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <span class="section-label">Common Questions</span>
      <h1 class="font-script text-6xl md:text-7xl text-gold mt-2">FAQ</h1>
      <p class="text-ink/60 mt-3 max-w-md mx-auto">
        Everything you need to know before placing your order.
      </p>
    </div>
  </section>

  <section class="py-16 bg-cream-light" aria-label="Frequently asked questions">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-14">

        <!-- FAQ accordion -->
        <div class="lg:col-span-2 reveal">
          <div class="mb-8">
            <span class="section-label">Frequently Asked</span>
            <h2 class="font-serif text-3xl text-ink mt-1">Your Questions, Answered</h2>
          </div>

          <div id="faq-list" class="divide-y divide-cream-dark">
            {faqs.map((item, i) => (
              <div class="faq-item py-1">
                <button
                  type="button"
                  aria-expanded="false"
                  aria-controls={`faq-answer-${i}`}
                  id={`faq-btn-${i}`}
                  class="faq-trigger w-full flex items-center justify-between gap-4 py-5 text-left font-serif text-ink hover:text-gold transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold rounded"
                >
                  <span class="text-base font-medium leading-snug">{item.q}</span>
                  <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full border border-gold/50 text-gold flex items-center justify-center text-sm transition-transform duration-300" aria-hidden="true">+</span>
                </button>
                <div
                  id={`faq-answer-${i}`}
                  role="region"
                  aria-labelledby={`faq-btn-${i}`}
                  class="faq-answer overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
                >
                  <p class="text-ink/65 text-sm leading-relaxed pb-5 pr-10">{item.a}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-10 p-6 bg-cream rounded-xl border border-cream-dark reveal">
            <p class="font-serif text-ink text-lg mb-2">Still have a question?</p>
            <p class="text-sm text-ink/60 mb-4">We're always happy to help. Reach out any time on WhatsApp for the fastest response.</p>
            <a
              href={`https://wa.me/${WA}?text=${encodeURIComponent("Hi Robyn! I have a question about placing an order. 🎂")}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Ask on WhatsApp
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6 reveal reveal-delay-2">
          <!-- Contact card -->
          <div class="bg-gold text-white rounded-2xl p-7 shadow-gold-md">
            <span class="text-xs uppercase tracking-widest text-white/70 font-semibold">Get in Touch</span>
            <h3 class="font-serif text-2xl text-white mt-2 mb-3">Let's Create Something Beautiful</h3>
            <p class="text-white/75 text-sm leading-relaxed mb-5">
              Ready to order or have a question? Reach out via WhatsApp for the fastest response.
            </p>
            <div class="space-y-3">
              <a
                href={`https://wa.me/${WA}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-3 bg-white text-gold rounded font-semibold text-sm hover:bg-cream-light transition-colors"
              >
                <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Message on WhatsApp
              </a>
              <a
                href={`https://www.instagram.com/${IG}`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-3 border border-white/40 text-white rounded font-semibold text-sm hover:bg-white/10 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Follow on Instagram
              </a>
              <a href="/enquiry" class="block text-center w-full py-3 border border-white/40 text-white rounded font-semibold text-sm hover:bg-white/10 transition-colors">
                Place an Order
              </a>
            </div>
          </div>

          <!-- Teaser image -->
          <div class="rounded-2xl overflow-hidden aspect-[4/3]">
            <img
              src="https://images.unsplash.com/photo-1464349095431-e9a21285b5f3?w=600&q=80"
              alt="Beautiful bespoke cake by Robyn"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const triggers = document.querySelectorAll<HTMLButtonElement>('.faq-trigger');

  triggers.forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer   = document.getElementById(btn.getAttribute('aria-controls')!)!;
      const icon     = btn.querySelector('.faq-icon')!;

      // Close all others
      triggers.forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherAnswer = document.getElementById(other.getAttribute('aria-controls')!)!;
          const otherIcon   = other.querySelector('.faq-icon')!;
          otherAnswer.style.maxHeight = '0';
          otherIcon.textContent = '+';
          otherIcon.classList.remove('rotate-45');
        }
      });

      // Toggle current
      btn.setAttribute('aria-expanded', String(!expanded));
      if (!expanded) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.textContent = '×';
        icon.classList.add('rotate-45');
      } else {
        answer.style.maxHeight = '0';
        icon.textContent = '+';
        icon.classList.remove('rotate-45');
      }
    });
  });
</script>
