---
const WA  = import.meta.env.PUBLIC_WHATSAPP_NUMBER  ?? '27000000000';
const IG  = import.meta.env.PUBLIC_INSTAGRAM_HANDLE ?? 'cake_byrobyn';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;

const shopLinks = [
  { href: `${base}shop`,                       label: 'All Cakes' },
  { href: `${base}shop?cat=wedding`,            label: 'Wedding Cakes' },
  { href: `${base}shop?cat=celebration`,        label: 'Celebration Cakes' },
  { href: `${base}shop?cat=cupcakes`,           label: 'Cupcakes' },
  { href: `${base}shop?cat=treats`,             label: 'Treats' },
];

const infoLinks = [
  { href: `${base}gallery`,  label: 'Gallery' },
  { href: `${base}pricing`,  label: 'Pricing Guide' },
  { href: `${base}faq`,      label: 'FAQ' },
  { href: `${base}enquiry`,  label: 'Custom Order' },
  { href: `${base}about`,    label: 'About Robyn' },
  { href: `${base}contact`,  label: 'Contact' },
];
---

<footer class="bg-ink text-white/80 mt-auto" aria-label="Site footer">
  <!-- Top section -->
  <div class="max-w-7xl mx-auto px-6 md:px-10 pt-16 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-1 flex flex-col gap-4">
        <a href="/" aria-label="Cake by Robyn — home" class="inline-flex items-center gap-3 group">
          <img
            src={`${base}brand/logo.png`}
            alt="Cake by Robyn"
            width="52"
            height="52"
            class="rounded-full ring-1 ring-gold/40 opacity-90 group-hover:opacity-100 transition-opacity"
            onerror="this.style.display='none'"
          />
          <span class="font-script text-3xl text-gold leading-none">Cake by Robyn</span>
        </a>
        <p class="text-sm text-white/55 leading-relaxed max-w-[220px]">
          Custom cakes made with love. Handcrafted in Johannesburg for every celebration.
        </p>
        <!-- Social -->
        <div class="flex gap-4 mt-1">
          <a
            href={`https://www.instagram.com/${IG}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`@${IG} on Instagram`}
            class="text-white/50 hover:text-gold transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={`https://wa.me/${WA}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Chat on WhatsApp"
            class="text-white/50 hover:text-[#25D366] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop links -->
      <div>
        <h3 class="text-white font-serif text-base mb-4">Shop</h3>
        <ul class="space-y-2" role="list">
          {shopLinks.map(l => (
            <li>
              <a href={l.href} class="text-sm text-white/55 hover:text-gold transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info links -->
      <div>
        <h3 class="text-white font-serif text-base mb-4">Info</h3>
        <ul class="space-y-2" role="list">
          {infoLinks.map(l => (
            <li>
              <a href={l.href} class="text-sm text-white/55 hover:text-gold transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact quick info -->
      <div>
        <h3 class="text-white font-serif text-base mb-4">Get in Touch</h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href={`https://wa.me/${WA}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/55 hover:text-[#25D366] transition-colors flex items-center gap-2"
            >
              <span class="text-[#25D366]">✦</span> WhatsApp
            </a>
          </li>
          <li>
            <a
              href={`https://www.instagram.com/${IG}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/55 hover:text-gold transition-colors flex items-center gap-2"
            >
              <span class="text-gold">✦</span> @{IG}
            </a>
          </li>
          <li>
            <a
              href={`${base}contact`}
              class="text-sm text-white/55 hover:text-gold transition-colors flex items-center gap-2"
            >
              <span class="text-gold">✦</span> Contact page
            </a>
          </li>
        </ul>

        <div class="mt-6 p-4 border border-gold/20 rounded">
          <p class="text-xs text-white/40 mb-2">Ready to order?</p>
          <a href={`${base}enquiry`} class="btn-gold text-xs px-5 py-2.5 w-full text-center">Start Your Order</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Thin gold rule -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/35">
        &copy; {year} Cake by Robyn. All rights reserved. Johannesburg, South Africa.
      </p>
      <p class="text-xs text-white/25">
        Crafted with love
      </p>
    </div>
  </div>
</footer>
