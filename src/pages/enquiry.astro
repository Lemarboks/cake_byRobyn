---
import BaseLayout from '../layouts/BaseLayout.astro';

const WA = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '27000000000';

const occasions = [
  'Birthday', 'Wedding', 'Baby Shower', 'Corporate Event',
  'Kids Party', 'Anniversary', 'Graduation', 'Other',
];

const servingOptions = [
  '1–10 (Bento / Small)',
  '10–20 (6-inch)',
  '20–40 (8-inch)',
  '40–80 (Tiered)',
  '80+ (Wedding)',
];

const budgetRanges = [
  'Under R500',
  'R500 – R1,000',
  'R1,000 – R2,000',
  'R2,000 – R4,000',
  'R4,000+',
  'Not sure yet',
];
---

<BaseLayout
  title="Custom Cake Enquiry"
  description="Request a bespoke custom cake. Tell us about your occasion, date, servings, theme, and budget and Robyn will bring your vision to life."
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <span class="section-label">Bespoke Orders</span>
      <h1 class="font-script text-6xl md:text-7xl text-gold mt-2">Custom Order</h1>
      <p class="text-ink/60 mt-3 max-w-md mx-auto">
        Tell us about your dream cake and we'll bring it to life.
      </p>
    </div>
  </section>

  <section class="py-16 bg-cream-light" aria-label="Custom cake enquiry">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Left info panel -->
        <aside class="lg:col-span-2 space-y-8 reveal">
          <div>
            <span class="section-label">How to Order</span>
            <h2 class="font-serif text-3xl text-ink mt-1">Let's Get Started</h2>
            <p class="text-ink/65 text-sm mt-3 leading-relaxed">
              Every cake is unique — just like you. Fill in the form and we'll reach out
              with a detailed quote within 24 hours. You can also send enquiry details
              directly via WhatsApp.
            </p>
          </div>

          <!-- Process steps -->
          <ol class="space-y-5" role="list">
            {[
              { num: '01', title: 'Fill in the form', desc: 'Tell us everything — occasion, size, flavour, design inspiration.' },
              { num: '02', title: 'Receive your quote', desc: 'We\'ll send a detailed, itemised quote within 24 hours.' },
              { num: '03', title: 'Secure your date', desc: 'Confirm with a 50% deposit to lock in your celebration date.' },
            ].map(step => (
              <li class="flex gap-4">
                <span class="w-8 h-8 rounded-full border border-gold/50 text-gold font-serif text-sm flex-shrink-0 flex items-center justify-center">
                  {step.num}
                </span>
                <div>
                  <p class="font-medium text-ink text-sm">{step.title}</p>
                  <p class="text-xs text-ink/55 mt-0.5">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>

          <!-- WhatsApp option -->
          <div class="p-5 border border-gold/25 rounded-xl bg-cream">
            <p class="text-sm font-medium text-ink mb-3">Prefer to chat directly?</p>
            <a
              id="wa-enquiry-link"
              href={`https://wa.me/${WA}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp w-full"
            >
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Send via WhatsApp
            </a>
            <p class="text-xs text-ink/40 mt-2 text-center">
              Fill the form first — we'll pre-fill your WhatsApp message.
            </p>
          </div>
        </aside>

        <!-- Form -->
        <div class="lg:col-span-3 reveal reveal-delay-1">
          <form
            id="enquiry-form"
            novalidate
            class="bg-cream rounded-2xl p-7 md:p-10 border border-cream-dark space-y-6"
            aria-label="Custom cake enquiry form"
          >

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="form-label">Your Name <span class="text-red-400" aria-hidden="true">*</span></label>
                <input id="name" name="name" type="text" required autocomplete="name"
                       placeholder="Jane Smith" class="form-input" />
              </div>
              <div>
                <label for="email" class="form-label">Email Address <span class="text-red-400" aria-hidden="true">*</span></label>
                <input id="email" name="email" type="email" required autocomplete="email"
                       placeholder="jane@email.com" class="form-input" />
              </div>
              <div>
                <label for="phone" class="form-label">Phone / WhatsApp</label>
                <input id="phone" name="phone" type="tel" autocomplete="tel"
                       placeholder="+27 82 000 0000" class="form-input" />
              </div>
              <div>
                <label for="date" class="form-label">Date Needed <span class="text-red-400" aria-hidden="true">*</span></label>
                <input id="date" name="date" type="date" required class="form-input" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="occasion" class="form-label">Occasion <span class="text-red-400" aria-hidden="true">*</span></label>
                <select id="occasion" name="occasion" required class="form-input">
                  <option value="">Select occasion</option>
                  {occasions.map(o => <option value={o.toLowerCase().replace(' ', '-')}>{o}</option>)}
                </select>
              </div>
              <div>
                <label for="servings" class="form-label">Number of Servings</label>
                <select id="servings" name="servings" class="form-input">
                  <option value="">Select servings</option>
                  {servingOptions.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>
            </div>

            <div>
              <label for="budget" class="form-label">Approximate Budget</label>
              <select id="budget" name="budget" class="form-input">
                <option value="">Select budget range</option>
                {budgetRanges.map(b => <option value={b}>{b}</option>)}
              </select>
            </div>

            <div>
              <label for="theme" class="form-label">Colour Palette / Theme</label>
              <input id="theme" name="theme" type="text"
                     placeholder="e.g. Dusty rose, gold, ivory — or a Pinterest board link"
                     class="form-input" />
            </div>

            <div>
              <label for="details" class="form-label">Design Inspiration &amp; Details <span class="text-red-400" aria-hidden="true">*</span></label>
              <textarea
                id="details"
                name="details"
                required
                rows="4"
                placeholder="Describe your dream cake — flavour, tiers, decorations, any reference images you love..."
                class="form-input resize-none"
              ></textarea>
            </div>

            <!-- Error message -->
            <div id="form-error" class="hidden text-sm text-red-500 bg-red-50 border border-red-200 rounded px-4 py-3" role="alert">
              Please fill in all required fields.
            </div>

            <!-- Success message -->
            <div id="form-success" class="hidden text-sm text-green-700 bg-green-50 border border-green-200 rounded px-4 py-3" role="status">
              Your WhatsApp message is ready! Click "Send via WhatsApp" above to submit your enquiry.
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              <button type="submit" class="btn-gold flex-1">
                Prepare WhatsApp Message
              </button>
              <a
                href="/shop"
                class="btn-ghost flex-1 text-center"
              >
                Browse Shop Instead
              </a>
            </div>

          </form>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ WA }}>
  const form     = document.getElementById('enquiry-form');
  const waLink   = document.getElementById('wa-enquiry-link');
  const errBox   = document.getElementById('form-error');
  const succBox  = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const name     = data.get('name')?.toString().trim()    ?? '';
    const email    = data.get('email')?.toString().trim()   ?? '';
    const date     = data.get('date')?.toString().trim()    ?? '';
    const occasion = data.get('occasion')?.toString().trim() ?? '';
    const servings = data.get('servings')?.toString().trim() ?? '';
    const budget   = data.get('budget')?.toString().trim()  ?? '';
    const theme    = data.get('theme')?.toString().trim()   ?? '';
    const details  = data.get('details')?.toString().trim() ?? '';

    if (!name || !email || !date || !occasion || !details) {
      errBox.classList.remove('hidden');
      succBox.classList.add('hidden');
      return;
    }
    errBox.classList.add('hidden');

    const lines = [
      `Hi Robyn! I'd like to enquire about a custom cake. 🎂`,
      ``,
      `*Name:* ${name}`,
      `*Email:* ${email}`,
      `*Date needed:* ${date}`,
      `*Occasion:* ${occasion}`,
      servings ? `*Servings:* ${servings}` : '',
      budget   ? `*Budget:* ${budget}`     : '',
      theme    ? `*Theme/Colours:* ${theme}` : '',
      ``,
      `*Details:*`,
      details,
    ].filter(Boolean).join('\n');

    waLink.href = `https://wa.me/${WA}?text=${encodeURIComponent(lines)}`;
    succBox.classList.remove('hidden');
    waLink.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
