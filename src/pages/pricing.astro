---
import BaseLayout from '../layouts/BaseLayout.astro';

const WA   = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '27000000000';
const base = import.meta.env.BASE_URL;

const pricingRows = [
  { name: 'Bento Cake',    price: 'R250',              note: 'Single-serve, fully decorated' },
  { name: '6-inch Cake',   price: 'From R650',         note: '10–15 servings' },
  { name: '8-inch Cake',   price: 'From R950',         note: '20–25 servings' },
  { name: 'Tiered Cakes',  price: 'From R1,800',       note: '2-tier upwards' },
  { name: 'Wedding Cakes', price: 'From R3,500',       note: 'Fully bespoke, consultation included' },
  { name: 'Cupcakes',      price: 'From R180 / dozen', note: 'Minimum 6 pieces' },
  { name: 'Cake Pops',     price: 'From R25 each',     note: 'Minimum order of 12' },
];

const includes = [
  {
    icon: '✦',
    title: 'Personalised Design',
    desc: 'We design specifically for your brief, not from a catalogue.',
  },
  {
    icon: '✦',
    title: 'Premium Ingredients',
    desc: 'Real butter, Belgian chocolate, and fresh local produce.',
  },
  {
    icon: '✦',
    title: 'Detailed Quote',
    desc: 'Itemised quote within 24 hours of your order request.',
  },
  {
    icon: '✦',
    title: 'Dedicated Support',
    desc: 'Direct communication with Robyn from order to delivery.',
  },
  {
    icon: '✦',
    title: 'Tasting (Weddings)',
    desc: 'Complimentary tasting session for wedding cake bookings.',
  },
  {
    icon: '✦',
    title: 'Beautiful Packaging',
    desc: 'Every cake is packaged with care, ready to present.',
  },
];

const waMsg = encodeURIComponent("Hi Robyn! I'd like to get a custom quote for a cake. 🎂");
---

<BaseLayout
  title="Pricing Guide"
  description="Transparent cake pricing from Cake by Robyn. Starting prices for bento cakes, birthday cakes, wedding cakes, cupcakes and more. Based in Johannesburg."
>

  <!-- Banner -->
  <section class="page-banner">
    <div class="max-w-7xl mx-auto px-6 md:px-10">
      <span class="section-label">Transparent Pricing</span>
      <h1 class="font-script text-6xl md:text-7xl text-gold mt-2">Pricing Guide</h1>
      <p class="text-ink/60 mt-3 max-w-md mx-auto">
        Starting prices for our most popular cakes. All designs can be fully customised.
      </p>
    </div>
  </section>

  <!-- Pricing table -->
  <section class="py-16 bg-cream-light" aria-labelledby="pricing-table-heading">
    <div class="max-w-5xl mx-auto px-6 md:px-10">

      <div class="reveal">
        <h2 id="pricing-table-heading" class="sr-only">Cake pricing table</h2>

        <!-- Table (desktop) -->
        <div class="hidden sm:block rounded-2xl overflow-hidden border border-cream-dark shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gold text-white">
                <th class="text-left px-7 py-4 font-semibold text-xs uppercase tracking-widest">Cake</th>
                <th class="text-left px-7 py-4 font-semibold text-xs uppercase tracking-widest">Starting Price</th>
                <th class="text-left px-7 py-4 font-semibold text-xs uppercase tracking-widest">Notes</th>
              </tr>
            </thead>
            <tbody>
              {pricingRows.map((row, i) => (
                <tr class:list={['border-t border-cream-dark transition-colors hover:bg-cream/60', i % 2 === 0 ? 'bg-cream-light' : 'bg-cream']}>
                  <td class="px-7 py-4 font-serif text-ink font-medium">{row.name}</td>
                  <td class="px-7 py-4 text-gold font-semibold">{row.price}</td>
                  <td class="px-7 py-4 text-ink/55">{row.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Card stack (mobile) -->
        <div class="sm:hidden space-y-3">
          {pricingRows.map(row => (
            <div class="bg-cream rounded-xl border border-cream-dark p-5 flex items-start justify-between gap-4">
              <div>
                <p class="font-serif text-ink font-medium">{row.name}</p>
                <p class="text-xs text-ink/50 mt-0.5">{row.note}</p>
              </div>
              <span class="text-gold font-semibold text-sm flex-shrink-0">{row.price}</span>
            </div>
          ))}
        </div>

        <p class="text-xs text-ink/45 mt-5 leading-relaxed">
          * Custom designs, premium decorations (edible gold leaf, sugar florals, etc.), and speciality ingredients may affect final pricing.
          You'll receive a full itemised quote within 24 hours of your enquiry.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mt-8 reveal">
        <a href={`${base}enquiry`} class="btn-gold">Get a Custom Quote</a>
        <a
          href={`https://wa.me/${WA}?text=${waMsg}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp"
        >
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Chat on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-16 bg-cream" aria-labelledby="includes-heading">
    <div class="max-w-5xl mx-auto px-6 md:px-10">
      <div class="text-center mb-12 reveal">
        <span class="section-label">What You Get</span>
        <h2 id="includes-heading" class="font-serif text-4xl text-ink mt-1">Every Cake Includes</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {includes.map((item, i) => (
          <div class:list={['bg-cream-light rounded-xl p-6 border border-cream-dark reveal', `reveal-delay-${Math.min(i % 3 + 1, 4)}`]}>
            <span class="text-gold text-2xl" aria-hidden="true">{item.icon}</span>
            <h3 class="font-serif text-ink text-base font-medium mt-3 mb-1">{item.title}</h3>
            <p class="text-xs text-ink/60 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gold CTA strip -->
  <section class="py-14 bg-gold text-center" aria-label="Order call to action">
    <div class="max-w-xl mx-auto px-6 reveal">
      <h2 class="font-script text-5xl text-white mb-3">Ready to order?</h2>
      <p class="text-white/80 text-sm mb-7">
        Every quote is free. Fill in the enquiry form and we'll get back to you within 24 hours.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}enquiry`} class="px-8 py-3.5 bg-white text-gold font-semibold rounded hover:bg-cream-light transition-colors text-sm">
          Start an Enquiry
        </a>
        <a href={`${base}shop`} class="px-8 py-3.5 border border-white/60 text-white font-semibold rounded hover:bg-white/10 transition-colors text-sm">
          Browse the Shop
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
