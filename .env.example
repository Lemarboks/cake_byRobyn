# Copy this file to .env and fill in your values.
# PUBLIC_ prefix exposes the variable to browser-side code.

# ── WhatsApp (enquiries only) ────────────────────────────────────────
# International format WITHOUT the + sign  e.g. 27821234567
PUBLIC_WHATSAPP_NUMBER=27000000000

# Instagram handle WITHOUT the @ sign
PUBLIC_INSTAGRAM_HANDLE=cake_byrobyn

# ── PayFast (online payments) ────────────────────────────────────────
# Get these from your PayFast merchant dashboard → Integration → Merchant Details
PUBLIC_PAYFAST_MERCHANT_ID=10000100
PUBLIC_PAYFAST_MERCHANT_KEY=46f0cd694581a

# Set to "true" for PayFast sandbox testing, "false" (or remove) for live payments
PUBLIC_PAYFAST_SANDBOX=true

# ── Site ─────────────────────────────────────────────────────────────
SITE_URL=https://lemarboks.github.io/cake_byRobyn
